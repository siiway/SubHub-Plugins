{
  "name": "@siiway/subhub-plugins",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SubHub 插件 monorepo：协议解析 / 订阅格式 / 中间件插件，按包发布到 npm。",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/siiway/SubHub-Plugins.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@siiway/subhub-plugin-sdk' build && bun run --filter '@siiway/subhub-plugin-*' build",
    "typecheck": "bun run build",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && node scripts/publish.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/workers-types": "^5.20260713.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
